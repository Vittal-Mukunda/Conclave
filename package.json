{
  "name": "conclave",
  "displayName": "conclave",
  "description": "Multi-model AI coding agent that orchestrates free and paid LLM APIs into an agentic coding loop.",
  "version": "0.0.1",
  "publisher": "conclave",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vittal-Mukunda/Conclave.git"
  },
  "bugs": {
    "url": "https://github.com/Vittal-Mukunda/Conclave/issues"
  },
  "homepage": "https://github.com/Vittal-Mukunda/Conclave#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "conclave",
          "title": "conclave",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "conclave": [
        {
          "type": "webview",
          "id": "conclave.panel",
          "name": "conclave"
        }
      ]
    },
    "commands": [
      {
        "command": "conclave.openPanel",
        "title": "conclave: Open Panel"
      },
      {
        "command": "conclave.reportIssue",
        "title": "conclave: Report Issue / Show Logs"
      },
      {
        "command": "conclave.checkConnectivity",
        "title": "conclave: Check Connectivity"
      },
      {
        "command": "conclave.manageKeys",
        "title": "conclave: Manage Provider Keys"
      },
      {
        "command": "conclave.setBudget",
        "title": "conclave: Cost Mode & Spend Cap"
      },
      {
        "command": "conclave.startOnboarding",
        "title": "conclave: Setup Wizard"
      },
      {
        "command": "conclave.initGit",
        "title": "conclave: Initialize Git Repository"
      },
      {
        "command": "conclave.localize",
        "title": "conclave: Localize Code for a Task"
      },
      {
        "command": "conclave.checkpoint",
        "title": "conclave: Checkpoint Working Tree"
      },
      {
        "command": "conclave.rememberTestCommand",
        "title": "conclave: Remember Test Command"
      },
      {
        "command": "conclave.verify",
        "title": "conclave: Verify Changes"
      },
      {
        "command": "conclave.runAgent",
        "title": "conclave: Run Agent"
      },
      {
        "command": "conclave.estimateDifficulty",
        "title": "conclave: Estimate Task Difficulty"
      },
      {
        "command": "conclave.recordFeedback",
        "title": "conclave: Rate Last Model Selection"
      },
      {
        "command": "conclave.planCouncil",
        "title": "conclave: Assign Author & Review Council"
      },
      {
        "command": "conclave.bestOfN",
        "title": "conclave: Best-of-N Selector Status"
      },
      {
        "command": "conclave.toggleSensitiveRepo",
        "title": "conclave: Toggle Sensitive-Repo Mode"
      },
      {
        "command": "conclave.refreshSkills",
        "title": "conclave: Refresh Installed Skills"
      },
      {
        "command": "conclave.findSkills",
        "title": "conclave: Find Skills for a Task"
      },
      {
        "command": "conclave.composeSkills",
        "title": "conclave: Compose Skills per Sub-Agent"
      },
      {
        "command": "conclave.scanSkills",
        "title": "conclave: Scan Installed Skills"
      },
      {
        "command": "conclave.searchSkills",
        "title": "conclave: Search Skill Marketplace"
      },
      {
        "command": "conclave.recoverRun",
        "title": "conclave: Recover Interrupted Run"
      },
      {
        "command": "conclave.cancelAgent",
        "title": "conclave: Cancel Running Agent"
      },
      {
        "command": "conclave.manageAccounts",
        "title": "conclave: Manage Account Pool"
      }
    ],
    "keybindings": [
      {
        "command": "conclave.openPanel",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:unit": "vitest run",
    "pretest:integration": "tsc -p tsconfig.test.json",
    "test:integration": "node ./out/test/integration/runTest.js",
    "test": "npm run test:unit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.2",
    "glob": "^10.3.10",
    "mocha": "^10.4.0",
    "typescript": "^5.4.5",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "node-sqlite3-wasm": "^0.8.58"
  }
}
